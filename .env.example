# Server酱 Turbo SendKey（https://sct.ftqq.com/sendkey）
# 格式类似 SCTxxxxxxxxxxxxxxxxxxxxxxxx
SERVERCHAN_SENDKEY=

# 默认预测城市（见 references/locations.md）
SUNSET_LOCATION=杭州

# 可选：sunset | sunrise
SUNSET_EVENT_TYPE=sunset

# 可选：Sunsethue 对照引擎
# SUNSETHUE_API_KEY=

# Vercel Cron / 手动触发鉴权（强烈建议在生产环境设置）
# 设置后调用 /api/cron 或 /api/predict?push=1 需带：
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
